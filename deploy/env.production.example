# Production .env for 31is.com on GoDaddy cPanel.
# Fill in the placeholders, then save as web/.env on the server.
# Bootstrap.sh will prompt for these interactively if they're missing.

APP_NAME=31is
APP_ENV=production
APP_KEY=                              # generated by `php artisan key:generate`
APP_DEBUG=false
APP_TIMEZONE=America/Chicago
APP_URL=http://app.31is.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# Subdomain routing
APP_PARENT_DOMAIN=31is.com
APP_DASHBOARD_SUBDOMAIN=app
APP_URL_SCHEME=http

# Per-user site cap (0 = unlimited; set 5 for production once cohorts grow)
USER_SITE_LIMIT=0

# MySQL — created in cPanel UI (Phase 1.3 of DEPLOY.md)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=__cpaneluser___31is_app
DB_USERNAME=__cpaneluser___31is_app
DB_PASSWORD=__set_in_cpanel__

# Sessions: HTTP-only mode, so don't require Secure cookies
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# Mail — cPanel SMTP
MAIL_MAILER=smtp
MAIL_HOST=__set_from_cpanel__
MAIL_PORT=587
MAIL_USERNAME=noreply@31is.com
MAIL_PASSWORD=__set_in_cpanel__
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@31is.com"
MAIL_FROM_NAME="${APP_NAME}"

# Optional: AI fill-in path. Leave blank to disable that creation option.
ANTHROPIC_API_KEY=
